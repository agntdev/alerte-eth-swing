[
  {
    "name": "/summary shows empty state",
    "steps": [
      {
        "send": { "text": "/summary" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📋 Aucun signal sur les dernières 24h."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "summary menu button shows same text",
    "steps": [
      {
        "send": { "callback": "summary:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📋 Aucun signal sur les dernières 24h."
            }
          }
        ]
      }
    ]
  }
]
