[
  {
    "name": "/mute shows duration options",
    "steps": [
      {
        "send": { "text": "/mute" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🔇 Pause les alertes pendant combien de temps ?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "mute menu button shows duration options",
    "steps": [
      {
        "send": { "callback": "mute:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "🔇 Pause les alertes pendant combien de temps ?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "selecting 1h mute confirms",
